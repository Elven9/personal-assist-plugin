{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "packages": {
    "plugins/prompt-logger": {
      "package-name": "prompt-logger",
      "component": "prompt-logger",
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "draft": false,
      "prerelease": false,
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/improve-english": {
      "package-name": "improve-english",
      "component": "improve-english",
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "draft": false,
      "prerelease": false,
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/daily-matters": {
      "package-name": "daily-matters",
      "component": "daily-matters",
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "draft": false,
      "prerelease": false,
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
